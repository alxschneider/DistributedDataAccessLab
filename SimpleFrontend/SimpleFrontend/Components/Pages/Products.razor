@page "/products"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory

<PageTitle>Products</PageTitle>

<h1>Products</h1>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (error != null)
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <table class="table table-striped table-bordered table-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th><th>Seller</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Discount%</th><th>Final Price</th><th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in products)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.SellerId</td>
                    <td>@p.Name</td>
                    <td>@p.Category</td>
                    <td>@p.Price.ToString("C")</td>
                    <td>@p.Stock</td>
                    <td>@p.DiscountPercent%</td>
                    <td>@p.FinalPrice.ToString("C")</td>
                    <td>@p.CreatedAt?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">Total: @products.Count</p>
}

@code {
    private bool loading = true;
    private string? error;
    private List<ProductRow> products = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var http = HttpFactory.CreateClient("Api");
            products = await http.GetFromJsonAsync<List<ProductRow>>("/api/products") ?? new();
        }
        catch (Exception ex) { error = ex.Message; }
        loading = false;
    }

    class ProductRow
    {
        public int Id { get; set; }
        public int SellerId { get; set; }
        public string Name { get; set; } = "";
        public string Category { get; set; } = "";
        public decimal Price { get; set; }
        public int Stock { get; set; }
        public decimal DiscountPercent { get; set; }
        public decimal FinalPrice { get; set; }
        public DateTime? CreatedAt { get; set; }
    }
}
