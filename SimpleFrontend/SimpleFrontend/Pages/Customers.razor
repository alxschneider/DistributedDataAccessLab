@page "/customers"
@inject ApiService Api

<PageTitle>Customers</PageTitle>

<h1>Customers</h1>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (error != null)
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <table class="table table-striped table-bordered table-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Address</th><th>Active</th><th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in customers)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.Name</td>
                    <td>@c.Email</td>
                    <td>@c.Phone</td>
                    <td><span class="badge @(c.Role == "Seller" ? "bg-warning text-dark" : "bg-info")">@c.Role</span></td>
                    <td>@c.Address</td>
                    <td>@(c.IsActive ? "Yes" : "No")</td>
                    <td>@c.CreatedAt?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">Total: @customers.Count</p>
}

@code {
    private bool loading = true;
    private string? error;
    private List<CustomerDto> customers = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            customers = await Api.GetCustomersAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        loading = false;
    }
}
