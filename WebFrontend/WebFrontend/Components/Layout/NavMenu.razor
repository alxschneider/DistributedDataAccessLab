@using WebFrontend.Services
@inject ProfileState Profile
@implements IDisposable

<nav class="fdu-main-nav">
    <div class="nav-inner">
        <a href="/" class="nav-item-link">Home</a>

        @if (Profile.IsAdmin)
        {
            <a href="/customers" class="nav-item-link">Customers</a>
            <a href="/products" class="nav-item-link">Products</a>
            <a href="/cart" class="nav-item-link">Cart</a>
            <a href="/orders" class="nav-item-link">Orders</a>
            <a href="/payments" class="nav-item-link">Payments</a>
            <a href="/notifications" class="nav-item-link">Notifications</a>
            <a href="/dashboard" class="nav-item-link">Dashboard</a>
        }
        else if (Profile.IsBuyer)
        {
            <a href="/products" class="nav-item-link">Courses</a>
            <a href="/cart" class="nav-item-link">Cart</a>
            <a href="/orders" class="nav-item-link">My Orders</a>
            <a href="/notifications" class="nav-item-link">Notifications</a>
            <a href="/dashboard" class="nav-item-link">Dashboard</a>
        }
        else if (Profile.IsSeller)
        {
            <a href="/products" class="nav-item-link">My Courses</a>
            <a href="/orders" class="nav-item-link">Orders</a>
            <a href="/payments" class="nav-item-link">Payments</a>
            <a href="/notifications" class="nav-item-link">Notifications</a>
            <a href="/dashboard" class="nav-item-link">Dashboard</a>
        }
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        Profile.OnChange += HandleProfileChange;
    }

    private void HandleProfileChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Profile.OnChange -= HandleProfileChange;
    }
}