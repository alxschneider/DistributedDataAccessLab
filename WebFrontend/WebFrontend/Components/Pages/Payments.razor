@page "/payments"
@using WebFrontend.Models
@using WebFrontend.Services
@inject PaymentService PaymentSvc
@inject CustomerService CustSvc
@inject ProfileState Profile
@rendermode InteractiveServer

<PageTitle>Payments — FDU Marketplace</PageTitle>

<h3>Payments</h3>

<div class="row mb-3 g-2">
    <div class="col-md-2">
        <input class="form-control" type="number" placeholder="Order ID" @bind="filterOrderId" />
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="filterBuyerId">
            <option value="">All Buyers</option>
            @foreach (var c in buyers)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="filterStatus">
            <option value="">All Status</option>
            <option value="Pending">Pending</option>
            <option value="Processing">Processing</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
            <option value="Refunded">Refunded</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" @onclick="LoadPayments">🔍 Search</button>
    </div>
    <div class="col-md-4 text-end">
        <button class="btn btn-success" @onclick="() => showForm = !showForm">➕ New Payment</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible">
        @message
        <button type="button" class="btn-close" @onclick="() => message = null"></button>
    </div>
}

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-header">Create Payment</div>
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Order ID</label>
                    <input class="form-control" type="number" @bind="newPayment.OrderId" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Buyer</label>
                    <select class="form-select" @bind="newPayment.BuyerId">
                        <option value="0">— Select Buyer —</option>
                        @foreach (var c in buyers)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Amount ($)</label>
                    <input class="form-control" type="number" step="0.01" @bind="newPayment.Amount" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Method</label>
                    <select class="form-select" @bind="newPayment.Method">
                        <option value="CreditCard">Credit Card</option>
                        <option value="Pix">Pix</option>
                        <option value="Boleto">Boleto</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary" @onclick="CreatePayment">Create</button>
                    <button class="btn btn-secondary ms-1" @onclick="() => showForm = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (payments == null)
{
    <p><em>Loading...</em></p>
}
else if (!payments.Any())
{
    <div class="alert alert-info">No payments found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Order</th>
                <th>Buyer</th>
                <th>Amount</th>
                <th>Method</th>
                <th>Status</th>
                <th>Created</th>
                <th>Processed</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in payments)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>#@p.OrderId</td>
                    <td>@CustomerName(p.BuyerId)</td>
                    <td>$ @p.Amount.ToString("N2")</td>
                    <td>
                        <span class="badge @GetMethodBadge(p.Method)">@p.Method</span>
                    </td>
                    <td>
                        <span class="badge @GetStatusBadge(p.Status)">@p.Status</span>
                    </td>
                    <td>@p.CreatedAt.ToString("dd/MM HH:mm")</td>
                    <td>@(p.ProcessedAt?.ToString("dd/MM HH:mm") ?? "—")</td>
                    <td>
                        @if (p.Status == "Pending")
                        {
                            <button class="btn btn-sm btn-primary" @onclick="() => ProcessPayment(p.Id)">
                                ⚡ Process
                            </button>
                        }
                        @if (p.Status == "Approved")
                        {
                            <button class="btn btn-sm btn-warning" @onclick="() => RefundPayment(p.Id)">
                                ↩️ Refund
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Payment>? payments;
    private int? filterOrderId, filterBuyerId;
    private string filterStatus = "";
    private bool showForm;
    private Payment newPayment = new() { Method = "CreditCard" };
    private string? message;
    private bool isError;
    private List<Customer> allCustomers = new();
    private IEnumerable<Customer> buyers => allCustomers.Where(c => c.Role == "Buyer");

    protected override async Task OnInitializedAsync()
    {
        try { allCustomers = await CustSvc.GetAllAsync(); } catch { }
        if (Profile.IsBuyer)
        {
            filterBuyerId = Profile.CurrentId;
            newPayment.BuyerId = Profile.CurrentId;
        }
        // Admin & Seller: no pre-filter, sees all
        await LoadPayments();
    }

    private string CustomerName(int id) => allCustomers.FirstOrDefault(c => c.Id == id)?.Name ?? $"#{id}";

    private async Task LoadPayments()
    {
        try { payments = await PaymentSvc.GetAllAsync(filterOrderId, filterBuyerId, filterStatus); }
        catch { payments = new(); }
    }

    private async Task CreatePayment()
    {
        var resp = await PaymentSvc.CreateAsync(newPayment);
        if (resp.IsSuccessStatusCode)
        {
            message = "Payment created!"; isError = false;
            showForm = false;
            newPayment = new() { Method = "CreditCard" };
            await LoadPayments();
        }
        else { message = $"Error: {await resp.Content.ReadAsStringAsync()}"; isError = true; }
    }

    private async Task ProcessPayment(int id)
    {
        message = "Processing payment... (mock 0-2s delay)"; isError = false;
        StateHasChanged();
        var resp = await PaymentSvc.ProcessAsync(id);
        if (resp.IsSuccessStatusCode)
        {
            var result = await resp.Content.ReadAsStringAsync();
            message = $"Payment processed! {result}"; isError = false;
            await LoadPayments();
        }
        else { message = $"Error: {await resp.Content.ReadAsStringAsync()}"; isError = true; }
    }

    private async Task RefundPayment(int id)
    {
        var resp = await PaymentSvc.RefundAsync(id);
        if (resp.IsSuccessStatusCode)
        {
            message = "Payment refunded!"; isError = false;
            await LoadPayments();
        }
        else { message = $"Error: {await resp.Content.ReadAsStringAsync()}"; isError = true; }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Pending" => "bg-secondary",
        "Processing" => "bg-fdu-burgundy",
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Refunded" => "bg-fdu-gold",
        _ => "bg-secondary"
    };

    private string GetMethodBadge(string method) => method switch
    {
        "CreditCard" => "bg-fdu-burgundy",
        "Pix" => "bg-success",
        "Boleto" => "bg-fdu-dark",
        _ => "bg-secondary"
    };
}
