@page "/orders"
@using WebFrontend.Models
@using WebFrontend.Services
@inject OrderService OrderSvc
@inject CustomerService CustSvc
@inject ProductService ProdSvc
@inject ProfileState Profile
@rendermode InteractiveServer

<PageTitle>Orders — FDU Marketplace</PageTitle>

<h3>Orders</h3>

<div class="row mb-3 g-2">
    <div class="col-md-3">
        <select class="form-select" @bind="filterBuyerId">
            <option value="">All Buyers</option>
            @foreach (var c in buyers)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="filterSellerId">
            <option value="">All Sellers</option>
            @foreach (var c in sellers)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="filterStatus">
            <option value="">All Status</option>
            <option value="AwaitingPayment">AwaitingPayment</option>
            <option value="Paid">Paid</option>
            <option value="Shipped">Shipped</option>
            <option value="Delivered">Delivered</option>
            <option value="Cancelled">Cancelled</option>
            <option value="Returned">Returned</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" @onclick="LoadOrders">🔍 Search</button>
    </div>
    <div class="col-md-4 text-end">
        <button class="btn btn-success" @onclick="() => showCreateForm = !showCreateForm">➕ New Order</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(globalMessage))
{
    <div class="alert @(isGlobalError ? "alert-danger" : "alert-success") alert-dismissible">
        @globalMessage
        <button type="button" class="btn-close" @onclick="() => globalMessage = null"></button>
    </div>
}

@if (showCreateForm)
{
    <div class="card mb-3">
        <div class="card-header">Create Order</div>
        <div class="card-body">
            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label">Buyer</label>
                    <select class="form-select" @bind="newOrder.BuyerId">
                        <option value="0">— Select Buyer —</option>
                        @foreach (var c in buyers)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
            </div>
            <h6>Items</h6>
            @for (int i = 0; i < newOrder.Items.Count; i++)
            {
                var idx = i;
                <div class="row g-2 mb-1">
                    <div class="col-md-5">
                        <select class="form-select" @bind="newOrder.Items[idx].ProductId">
                            <option value="0">— Select Product —</option>
                            @foreach (var p in productList)
                            {
                                <option value="@p.Id">@p.Name ($ @p.FinalPrice.ToString("N2"))</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input class="form-control" type="number" placeholder="Qty" @bind="newOrder.Items[idx].Quantity" />
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => newOrder.Items.RemoveAt(idx)">✕</button>
                    </div>
                </div>
            }
            <button class="btn btn-sm btn-outline-secondary mb-2" @onclick="() => newOrder.Items.Add(new())">+ Add Item</button>
            <div>
                <button class="btn btn-primary" @onclick="CreateOrder">Create Order</button>
                <button class="btn btn-secondary ms-2" @onclick="() => showCreateForm = false">Cancel</button>
            </div>
        </div>
    </div>
}

@if (orders == null)
{
    <p><em>Loading...</em></p>
}
else if (!orders.Any())
{
    <div class="alert alert-info">No orders found.</div>
}
else
{
    @foreach (var o in orders)
    {
        <div class="card mb-2">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <strong>Order #@o.Id</strong> — @CustomerName(o.BuyerId) —
                    <span class="badge @GetStatusBadge(o.Status)">@o.Status</span>
                    — <strong>$ @o.Total.ToString("N2")</strong>
                </span>
                <span class="text-muted">@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="card-body p-2">
                @if (o.Items.Any())
                {
                    <table class="table table-sm mb-2">
                        <thead>
                            <tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Discount</th><th>Subtotal</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in o.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>$ @item.UnitPrice.ToString("N2")</td>
                                    <td>$ @item.Discount.ToString("N2")</td>
                                    <td>$ @item.Subtotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <div class="d-flex gap-2 flex-wrap">
                    @if (o.Status == "AwaitingPayment")
                    {
                        <button class="btn btn-sm btn-success" @onclick="() => MarkPaid(o.Id)">Mark Paid</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ShowCancelDialog(o.Id)">Cancel</button>
                    }
                    @if (o.Status == "Paid")
                    {
                        <button class="btn btn-sm btn-primary" @onclick="() => MarkShipped(o.Id)">Ship</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ShowCancelDialog(o.Id)">Cancel</button>
                    }
                    @if (o.Status == "Shipped")
                    {
                        <button class="btn btn-sm btn-success" @onclick="() => MarkDelivered(o.Id)">Delivered</button>
                    }
                    @if (o.Status == "Delivered")
                    {
                        <button class="btn btn-sm btn-warning" @onclick="() => ShowReturnDialog(o.Id)">Return</button>
                    }
                </div>

                @if (o.CancelledAt.HasValue)
                {
                    <small class="text-danger">Cancelled at @o.CancelledAt.Value.ToString("dd/MM/yyyy") — @o.CancellationReason</small>
                }
                @if (o.ReturnedAt.HasValue)
                {
                    <small class="text-warning">Returned at @o.ReturnedAt.Value.ToString("dd/MM/yyyy") — @o.ReturnReason</small>
                }
            </div>
        </div>
    }
}

@if (showCancelDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Cancel Order #@dialogOrderId</h5>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason (optional)</label>
                    <input class="form-control" @bind="dialogReason" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showCancelDialog = false">Close</button>
                    <button class="btn btn-danger" @onclick="ConfirmCancel">Confirm Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showReturnDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Return Order #@dialogOrderId</h5>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason (optional)</label>
                    <input class="form-control" @bind="dialogReason" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showReturnDialog = false">Close</button>
                    <button class="btn btn-warning" @onclick="ConfirmReturn">Confirm Return</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Order>? orders;
    private int? filterBuyerId, filterSellerId;
    private string filterStatus = "";
    private bool showCreateForm;
    private CreateOrderRequest newOrder = new() { Items = new() { new() } };
    private string? globalMessage;
    private bool isGlobalError;

    private bool showCancelDialog, showReturnDialog;
    private int dialogOrderId;
    private string dialogReason = "";

    private List<Customer> allCustomers = new();
    private List<Product> productList = new();
    private IEnumerable<Customer> buyers => allCustomers.Where(c => c.Role == "Buyer");
    private IEnumerable<Customer> sellers => allCustomers.Where(c => c.Role == "Seller");

    protected override async Task OnInitializedAsync()
    {
        await LoadLookups();
        if (Profile.IsBuyer)
        {
            filterBuyerId = Profile.CurrentId;
            newOrder.BuyerId = Profile.CurrentId;
        }
        else if (Profile.IsSeller)
            filterSellerId = Profile.CurrentId;
        // Admin: no pre-filter, sees all
        await LoadOrders();
    }

    private async Task LoadLookups()
    {
        try { allCustomers = await CustSvc.GetAllAsync(); } catch { }
        try { productList = await ProdSvc.GetAllAsync(); } catch { }
    }

    private string CustomerName(int id) => allCustomers.FirstOrDefault(c => c.Id == id)?.Name ?? $"#{id}";

    private async Task LoadOrders()
    {
        try { orders = await OrderSvc.GetAllAsync(filterBuyerId, filterSellerId, filterStatus); }
        catch { orders = new(); }
    }

    private async Task CreateOrder()
    {
        var resp = await OrderSvc.CreateAsync(newOrder);
        if (resp.IsSuccessStatusCode)
        {
            globalMessage = "Order created!"; isGlobalError = false;
            showCreateForm = false;
            newOrder = new() { Items = new() { new() } };
            await LoadOrders();
        }
        else
        {
            globalMessage = $"Error: {await resp.Content.ReadAsStringAsync()}"; isGlobalError = true;
        }
    }

    private async Task UpdateStatus(int id, string status)
    {
        var resp = await OrderSvc.UpdateStatusAsync(id, status);
        if (resp.IsSuccessStatusCode) { await LoadOrders(); globalMessage = $"Order #{id} → {status}"; isGlobalError = false; }
        else { globalMessage = $"Error: {await resp.Content.ReadAsStringAsync()}"; isGlobalError = true; }
    }

    private Task MarkPaid(int id) => UpdateStatus(id, "Paid");
    private Task MarkShipped(int id) => UpdateStatus(id, "Shipped");
    private Task MarkDelivered(int id) => UpdateStatus(id, "Delivered");

    private void ShowCancelDialog(int id) { dialogOrderId = id; dialogReason = ""; showCancelDialog = true; }
    private void ShowReturnDialog(int id) { dialogOrderId = id; dialogReason = ""; showReturnDialog = true; }

    private async Task ConfirmCancel()
    {
        var resp = await OrderSvc.CancelAsync(dialogOrderId, dialogReason);
        showCancelDialog = false;
        if (resp.IsSuccessStatusCode) { globalMessage = $"Order #{dialogOrderId} cancelled."; isGlobalError = false; await LoadOrders(); }
        else { globalMessage = $"Error: {await resp.Content.ReadAsStringAsync()}"; isGlobalError = true; }
    }

    private async Task ConfirmReturn()
    {
        var resp = await OrderSvc.ReturnAsync(dialogOrderId, dialogReason);
        showReturnDialog = false;
        if (resp.IsSuccessStatusCode) { globalMessage = $"Order #{dialogOrderId} returned."; isGlobalError = false; await LoadOrders(); }
        else { globalMessage = $"Error: {await resp.Content.ReadAsStringAsync()}"; isGlobalError = true; }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "AwaitingPayment" => "bg-secondary",
        "Paid" => "bg-success",
        "Shipped" => "bg-fdu-burgundy",
        "Delivered" => "bg-fdu-dark",
        "Cancelled" => "bg-danger",
        "Returned" => "bg-fdu-gold",
        _ => "bg-secondary"
    };
}
