@page "/customers"
@using WebFrontend.Models
@using WebFrontend.Services
@inject CustomerService CustomerSvc
@inject ProfileState Profile
@rendermode InteractiveServer

<PageTitle>Customers — FDU Marketplace</PageTitle>

<h3>Customers</h3>

<div class="row mb-3">
    <div class="col-md-3">
        <select class="form-select" @bind="filterRole">
            <option value="">All Roles</option>
            <option value="Buyer">Buyer</option>
            <option value="Seller">Seller</option>
        </select>
    </div>
    <div class="col-md-4">
        <input class="form-control" placeholder="Search by name or email..." @bind="searchTerm" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" @onclick="LoadCustomers">🔍 Search</button>
    </div>
    <div class="col-md-3 text-end">
        <button class="btn btn-success" @onclick="ShowCreate">➕ New Customer</button>
    </div>
</div>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-header">@(editingId.HasValue ? "Edit Customer" : "New Customer")</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="form.Name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input class="form-control" type="email" @bind="form.Email" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phone</label>
                    <input class="form-control" @bind="form.Phone" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Document (CPF/CNPJ)</label>
                    <input class="form-control" @bind="form.Document" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Role</label>
                    <select class="form-select" @bind="form.Role">
                        <option value="Buyer">Buyer</option>
                        <option value="Seller">Seller</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Address</label>
                    <input class="form-control" @bind="form.Address" />
                </div>
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button class="btn btn-primary" @onclick="SaveCustomer">💾 Save</button>
                    <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @(isError ? "alert-danger" : "alert-success") mt-2 mb-0">@message</div>
            }
        </div>
    </div>
}

@if (customers == null)
{
    <p><em>Loading...</em></p>
}
else if (!customers.Any())
{
    <div class="alert alert-info">No customers found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Role</th>
                <th>Document</th>
                <th>Active</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in customers)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.Name</td>
                    <td>@c.Email</td>
                    <td>@c.Phone</td>
                    <td><span class="badge @(c.Role == "Seller" ? "bg-fdu-gold" : "bg-fdu-burgundy")">@c.Role</span></td>
                    <td>@c.Document</td>
                    <td>@(c.IsActive ? "✅" : "❌")</td>
                    <td>@c.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(c)">✏️</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(c.Id)">🗑️</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Customer>? customers;
    private Customer form = new();
    private bool showForm;
    private int? editingId;
    private string? message;
    private bool isError;
    private string filterRole = "";
    private string searchTerm = "";

    protected override async Task OnInitializedAsync() => await LoadCustomers();

    private async Task LoadCustomers()
    {
        try { customers = await CustomerSvc.GetAllAsync(filterRole, searchTerm); }
        catch { customers = new(); }
    }

    private void ShowCreate()
    {
        form = new Customer { Role = "Buyer" };
        editingId = null;
        showForm = true;
        message = null;
    }

    private void Edit(Customer c)
    {
        form = new Customer
        {
            Name = c.Name, Email = c.Email, Phone = c.Phone,
            Document = c.Document, Role = c.Role, Address = c.Address
        };
        editingId = c.Id;
        showForm = true;
        message = null;
    }

    private void CancelForm() { showForm = false; message = null; }

    private async Task SaveCustomer()
    {
        HttpResponseMessage resp;
        if (editingId.HasValue)
            resp = await CustomerSvc.UpdateAsync(editingId.Value, form);
        else
            resp = await CustomerSvc.CreateAsync(form);

        if (resp.IsSuccessStatusCode)
        {
            message = editingId.HasValue ? "Customer updated!" : "Customer created!";
            isError = false;
            showForm = false;
            await LoadCustomers();
            Profile.NotifyCustomersChanged();
        }
        else
        {
            message = $"Error: {await resp.Content.ReadAsStringAsync()}";
            isError = true;
        }
    }

    private async Task Delete(int id)
    {
        var resp = await CustomerSvc.DeleteAsync(id);
        if (resp.IsSuccessStatusCode)
        {
            await LoadCustomers();
            Profile.NotifyCustomersChanged();
        }
    }
}
