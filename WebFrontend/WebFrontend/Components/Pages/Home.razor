@page "/"
@using WebFrontend.Models
@using WebFrontend.Services
@inject ProfileState Profile
@inject CustomerService CustSvc
@inject ProductService ProductSvc
@inject CartService CartSvc
@inject NavigationManager Nav
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>FDU Marketplace</PageTitle>

@if (Profile.IsAdmin)
{
    <div class="py-4 px-4 mb-4" style="background: var(--fdu-navy); color: #fff;">
        <h1 style="color:#fff; margin:0;">Admin Control Panel</h1>
        <p class="lead mb-0" style="color:rgba(255,255,255,0.75);">Distributed Microservices Lab — Full Access</p>
    </div>

    @if (!customersExist)
    {
        <div class="alert alert-info mt-3 mx-4" style="border-left: 4px solid var(--fdu-red);">
            <h5>Welcome!</h5>
            <p>No customers registered yet. Create your first customer to get started.</p>
            <a href="/customers" class="btn btn-primary btn-lg">Create Customer</a>
        </div>
    }

    <div class="row g-3 mt-2 px-4">
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Customers</h5>
                    <p class="text-muted">Manage Buyers &amp; Sellers</p>
                    <a href="/customers" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Products</h5>
                    <p class="text-muted">Manage the catalog</p>
                    <a href="/products" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Cart</h5>
                    <p class="text-muted">Shopping carts</p>
                    <a href="/cart" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Orders</h5>
                    <p class="text-muted">All orders</p>
                    <a href="/orders" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Payments</h5>
                    <p class="text-muted">All payments</p>
                    <a href="/payments" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Notifications</h5>
                    <p class="text-muted">All notifications</p>
                    <a href="/notifications" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
    </div>
    <div class="text-center mt-4 mb-4">
        <a href="/dashboard" class="btn btn-lg btn-dark">Dashboard</a>
    </div>
}
else if (Profile.IsBuyer)
{
    <!-- Buyer storefront -->
    <div class="py-4 px-4 mb-4" style="background: var(--fdu-navy); color: #fff;">
        <h1 style="color:#fff; margin:0;">Welcome to FDU Vancouver</h1>
        <p class="lead mb-1" style="color:rgba(255,255,255,0.75);">Explore our world-class programs and enroll today</p>
        <p class="mb-3" style="color:rgba(255,255,255,0.6);">Logged in as <strong>@Profile.CurrentCustomer!.Name</strong></p>
        <a href="/products" class="btn btn-sm text-white" style="background: var(--fdu-red); border: none;">Browse All Courses &rarr;</a>
    </div>

    @if (featuredCourses != null && featuredCourses.Any())
    {
        <h4 class="mb-3 px-4">Featured Courses</h4>
        <div class="row g-3 mb-4 px-4">
            @foreach (var course in featuredCourses.Take(4))
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0">
                        <div style="height: 160px; overflow: hidden;">
                            <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "https://images.unsplash.com/photo-1523050854058-8df90110c476?w=400" : course.ImageUrl)"
                                 alt="@course.Name" style="width: 100%; height: 100%; object-fit: cover;" />
                        </div>
                        <div class="card-body d-flex flex-column">
                            <span class="badge mb-2" style="background: var(--fdu-burgundy); width: fit-content;">@course.Category</span>
                            <h6 class="card-title fw-bold">@course.Name</h6>
                            <p class="text-muted small flex-grow-1">@TruncateText(course.Description, 80)</p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="fw-bold fs-5" style="color: var(--fdu-navy);">
                                    @if (course.DiscountPercent > 0)
                                    {
                                        <small class="text-decoration-line-through text-muted me-1">$ @course.Price.ToString("N2")</small>
                                    }
                                    $ @course.FinalPrice.ToString("N2")
                                </span>
                                <button class="btn btn-sm text-white" style="background: var(--fdu-red);"
                                        @onclick="() => AddToCart(course)">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="row g-3 px-4">
        <div class="col-md-3">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>My Cart</h5>
                    <p class="text-muted">Review &amp; checkout</p>
                    <a href="/cart" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>My Orders</h5>
                    <p class="text-muted">Track your orders</p>
                    <a href="/orders" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Notifications</h5>
                    <p class="text-muted">View your alerts</p>
                    <a href="/notifications" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Dashboard</h5>
                    <p class="text-muted">Your stats</p>
                    <a href="/dashboard" class="btn btn-dark btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(cartMessage))
    {
        <div class="alert alert-success mt-3 alert-dismissible fade show">
            @cartMessage
            <button type="button" class="btn-close" @onclick="() => cartMessage = null"></button>
        </div>
    }
}
else if (Profile.IsSeller)
{
    <div class="py-4 px-4 mb-4" style="background: var(--fdu-navy); color: #fff;">
        <h1 style="color:#fff; margin:0;">Your Store — @Profile.CurrentCustomer!.Name</h1>
        <p class="lead mb-0" style="color:rgba(255,255,255,0.75);">Manage your courses and track sales</p>
    </div>

    <div class="row g-3 mt-2 px-4">
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>My Courses</h5>
                    <p class="text-muted">Manage your course catalog</p>
                    <a href="/products" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Orders</h5>
                    <p class="text-muted">Orders with your courses</p>
                    <a href="/orders" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Payments</h5>
                    <p class="text-muted">Track payments</p>
                    <a href="/payments" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Notifications</h5>
                    <p class="text-muted">View your alerts</p>
                    <a href="/notifications" class="btn btn-primary btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0" style="border-left: 4px solid var(--fdu-red) !important;">
                <div class="card-body">
                    <h5>Dashboard</h5>
                    <p class="text-muted">Your store analytics</p>
                    <a href="/dashboard" class="btn btn-dark btn-sm">Open &rarr;</a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool customersExist;
    private List<Product>? featuredCourses;
    private string? cartMessage;

    protected override async Task OnInitializedAsync()
    {
        Profile.OnChange += HandleProfileChange;
        try
        {
            var customers = await CustSvc.GetAllAsync();
            customersExist = customers.Any();
        }
        catch { customersExist = false; }

        if (Profile.IsBuyer)
        {
            try { featuredCourses = await ProductSvc.GetAllAsync(); }
            catch { featuredCourses = new(); }
        }
    }

    private string TruncateText(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "…";

    private async Task AddToCart(Product course)
    {
        try
        {
            var resp = await CartSvc.AddItemAsync(Profile.CurrentId, course.Id, 1);
            cartMessage = resp.IsSuccessStatusCode
                ? $"✅ \"{course.Name}\" added to cart!"
                : $"⚠️ Could not add to cart.";
        }
        catch { cartMessage = "⚠️ Cart service unavailable."; }
    }

    private void HandleProfileChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Profile.OnChange -= HandleProfileChange;
    }
}
