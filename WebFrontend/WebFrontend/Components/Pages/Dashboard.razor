@page "/dashboard"
@using System.Text.Json
@using WebFrontend.Models
@using WebFrontend.Services
@inject CustomerService CustomerSvc
@inject ProfileState Profile
@rendermode InteractiveServer

<PageTitle>Dashboard — FDU Marketplace</PageTitle>

<h3>Dashboard</h3>

<button class="btn btn-primary mb-3" @onclick="LoadAll">🔄 Refresh All</button>

@if (loading)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}

<div class="row g-3">
    @if (customerDash != null)
    {
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-fdu-burgundy text-white">👥 Customers</div>
                <div class="card-body">
                    <pre class="mb-0" style="white-space: pre-wrap;">@FormatJson(customerDash)</pre>
                </div>
            </div>
        </div>
    }

    @if (productDash != null)
    {
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-fdu-dark text-white">📦 Products</div>
                <div class="card-body">
                    <pre class="mb-0" style="white-space: pre-wrap;">@FormatJson(productDash)</pre>
                </div>
            </div>
        </div>
    }

    @if (orderDash != null)
    {
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-fdu-burgundy text-white">🛒 Orders</div>
                <div class="card-body">
                    <pre class="mb-0" style="white-space: pre-wrap;">@FormatJson(orderDash)</pre>
                </div>
            </div>
        </div>
    }

    @if (paymentDash != null)
    {
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-fdu-gold">💳 Payments</div>
                <div class="card-body">
                    <pre class="mb-0" style="white-space: pre-wrap;">@FormatJson(paymentDash)</pre>
                </div>
            </div>
        </div>
    }

    @if (notifDash != null)
    {
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-secondary text-white">🔔 Notifications</div>
                <div class="card-body">
                    <pre class="mb-0" style="white-space: pre-wrap;">@FormatJson(notifDash)</pre>
                </div>
            </div>
        </div>
    }
</div>

<hr />

<h5>Personal Dashboard</h5>
<div class="row g-2 mb-3">
    <div class="col-md-3">
        <div class="input-group">
            <span class="input-group-text">Customer</span>
            <select class="form-select" @bind="personalId">
                <option value="0">— Select Customer —</option>
                @foreach (var c in allCustomers)
                {
                    <option value="@c.Id">@c.Name (@c.Role)</option>
                }
            </select>
            <button class="btn btn-outline-primary" @onclick="LoadPersonal">Load</button>
        </div>
    </div>
</div>

@if (personalDash != null)
{
    <div class="card">
        <div class="card-header bg-fdu-dark text-white">Personal Dashboard — @CustomerName(personalId)</div>
        <div class="card-body">
            <pre class="mb-0" style="white-space: pre-wrap;">@FormatJson(personalDash)</pre>
        </div>
    </div>
}

@code {
    private object? customerDash, productDash, orderDash, paymentDash, notifDash, personalDash;
    private bool loading;
    private int personalId;
    private List<Customer> allCustomers = new();

    [Inject] IConfiguration Config { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try { allCustomers = await CustomerSvc.GetAllAsync(); } catch { }
        if (Profile.HasProfile)
            personalId = Profile.CurrentId;
        await LoadAll();
        if (personalId > 0)
            await LoadPersonal();
    }

    private string CustomerName(int id) => allCustomers.FirstOrDefault(c => c.Id == id)?.Name ?? $"#{id}";

    private async Task LoadAll()
    {
        loading = true;
        StateHasChanged();

        try { customerDash = await CustomerSvc.GetDashboardAsync(); } catch { customerDash = null; }
        try { productDash = await FetchDash("ProductService", "api/products/dashboard"); } catch { productDash = null; }
        try { orderDash = await FetchDash("OrderService", "api/orders/dashboard"); } catch { orderDash = null; }
        try { paymentDash = await FetchDash("PaymentService", "api/payments/dashboard"); } catch { paymentDash = null; }
        try { notifDash = await FetchDash("NotificationService", "api/notifications/dashboard"); } catch { notifDash = null; }

        loading = false;
    }

    private async Task LoadPersonal()
    {
        if (personalId <= 0) return;
        try { personalDash = await CustomerSvc.GetPersonalDashboardAsync(personalId); }
        catch { personalDash = null; }
    }

    private async Task<object?> FetchDash(string service, string path)
    {
        var baseUrl = Config[$"Services:{service}"] ?? service switch
        {
            "ProductService" => "http://localhost:5003",
            "OrderService" => "http://localhost:5002",
            "PaymentService" => "http://localhost:5006",
            "NotificationService" => "http://localhost:5004",
            _ => ""
        };
        using var http = new HttpClient { BaseAddress = new Uri(baseUrl) };
        return await http.GetFromJsonAsync<object>(path);
    }

    private string FormatJson(object? obj)
    {
        if (obj == null) return "No data";
        try
        {
            if (obj is JsonElement je)
                return JsonSerializer.Serialize(je, new JsonSerializerOptions { WriteIndented = true });
            return JsonSerializer.Serialize(obj, new JsonSerializerOptions { WriteIndented = true });
        }
        catch { return obj.ToString() ?? ""; }
    }
}
