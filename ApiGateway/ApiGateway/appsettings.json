{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "CustomerService": "http://customerservice:8080/",
    "ProductService": "http://productservice:8080/",
    "OrderService": "http://orderservice:8080/",
    "NotificationService": "http://notificationservice:8080/",
    "CartService": "http://cartservice:8080/",
    "PaymentService": "http://paymentservice:8080/"
  },
  "ReverseProxy": {
    "Routes": {
      "customers-route": {
        "ClusterId": "customerservice",
        "Match": {
          "Path": "/api/customers/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/customers/{**catch-all}" }
        ]
      },
      "products-route": {
        "ClusterId": "productservice",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/products/{**catch-all}" }
        ]
      },
      "orders-route": {
        "ClusterId": "orderservice",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/orders/{**catch-all}" }
        ]
      },
      "notifications-route": {
        "ClusterId": "notificationservice",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/notifications/{**catch-all}" }
        ]
      },
      "cart-route": {
        "ClusterId": "cartservice",
        "Match": {
          "Path": "/api/cart/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/cart/{**catch-all}" }
        ]
      },
      "payments-route": {
        "ClusterId": "paymentservice",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/payments/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "customerservice": {
        "Destinations": {
          "default": {
            "Address": "http://customerservice:8080/"
          }
        }
      },
      "productservice": {
        "Destinations": {
          "default": {
            "Address": "http://productservice:8080/"
          }
        }
      },
      "orderservice": {
        "Destinations": {
          "default": {
            "Address": "http://orderservice:8080/"
          }
        }
      },
      "notificationservice": {
        "Destinations": {
          "default": {
            "Address": "http://notificationservice:8080/"
          }
        }
      },
      "cartservice": {
        "Destinations": {
          "default": {
            "Address": "http://cartservice:8080/"
          }
        }
      },
      "paymentservice": {
        "Destinations": {
          "default": {
            "Address": "http://paymentservice:8080/"
          }
        }
      }
    }
  }
}
